# =============================================================================
# Learno Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...          # Required. Get from https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o            # Optional. Default: gpt-4o
OPENAI_MAX_TOKENS=500          # Optional. Default: 500
OPENAI_TEMPERATURE=0.7         # Optional. Default: 0.7

# -----------------------------------------------------------------------------
# Database
# SQLite (development — default):
DATABASE_URL=sqlite:///./learno.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/learno
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# JWT — MUST be overridden in production with a strong random secret.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins.
# Use * for development (credentials will be disabled when wildcard is set).
# Set to your exact frontend origin(s) in production.
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=*
# ALLOWED_ORIGINS=https://app.learno.com,https://www.learno.com

# -----------------------------------------------------------------------------
# Session & behaviour
# -----------------------------------------------------------------------------
SESSION_TIMEOUT_SECONDS=1800   # 30 minutes
SILENCE_THRESHOLD_SECONDS=12
DEBUG=true                     # Set to false in production
